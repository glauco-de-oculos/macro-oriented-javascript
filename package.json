{
  "name": "@icaroglauco/dsljs",
  "version": "0.1.1",
  "author": "Ícaro Glauco de Oliveira",
  "description": "IDSL macro system and structural expander for JavaScript",
  "keywords": [
    "dsl",
    "macro",
    "macros",
    "javascript",
    "vite",
    "eslint",
    "idsl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glauco-asked-plugin/macro-oriented-javascript.git"
  },
  "homepage": "https://github.com/glauco-asked-plugin/macro-oriented-javascript#readme",
  "bugs": {
    "url": "https://github.com/glauco-asked-plugin/macro-oriented-javascript/issues"
  },
  "bin": {
    "dsljs": "bin/dsljs.js",
    "idsl": "bin/dsljs.js"
  },
  "type": "module",
  "exports": {
    ".": "./src/parser.js",
    "./vite": "./src/vite-plugin.js",
    "./eslint-config": "./eslint.config.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "bin",
    "editor/dsljs-tools",
    "eslint",
    "eslint.config.js",
    "eslint.config.typescript.js",
    "scripts/setup-vscode.js",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "_example": "node src/parser.js example/example.dsljs",
    "lint": "eslint .",
    "postinstall": "node scripts/setup-vscode.js",
    "shadow:example": "dsljs shadow example/example.dsljs",
    "shadow:watch:example": "dsljs watch-shadow example/example.dsljs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "chokidar": "^5.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "url": "^0.11.4"
  }
}
